# ──────────────────────────────────────────────────────────────────────────────
# GitGuild 生产环境变量模板
# 用法：在服务器上 cp deploy/.env.prod.example deploy/.env.prod 后填真实值。
# 然后：docker compose --env-file deploy/.env.prod -f docker-compose.prod.yml up -d --build
# deploy/.env.prod 已被 .gitignore 忽略，不要提交。
# ──────────────────────────────────────────────────────────────────────────────

# ── 对外访问（IP:端口直连）──────────────────────────────────────────────────
# 服务器公网/内网 IP，用于生成 Gitea clone URL。必填，不能写 localhost。
SERVER_IP=YOUR_SERVER_IP

# 对外端口。先用 deploy/probe.sh 探测占用，被占就改这里。
HTTP_PORT=80          # 前端站点 → http://SERVER_IP:HTTP_PORT
GITEA_PORT=3000       # Gitea Web → http://SERVER_IP:GITEA_PORT
GITEA_SSH_PORT=2222   # Gitea SSH（git clone over ssh）
BACKEND_PORT=8080     # 仅调试/Swagger，可选关闭（删 compose 里 backend.ports）

# ── MySQL（仅容器内网，不对外暴露）──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_pw
MYSQL_USER=gitguild
MYSQL_PASSWORD=CHANGE_ME_strong_app_pw

# ── JWT（必填，>=32 字符随机串）─────────────────────────────────────────────
# 生成：  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_EXPIRATION_MS=86400000

# ── Gitea ────────────────────────────────────────────────────────────────────
# 默认值匹配随仓库分发的 gitea 快照（seed/gitea-data.tar.gz 内 spike-admin 的 token）。
# 若首次启动后仓库导入报 token 失效，按 README「Gitea token 校验/重签」重置后填这里。
GITEA_TOKEN=a0a65becdcda71c75fce3c4328e1c37b52b5c15a
GITEA_ADMIN_USERNAME=spike-admin

# 迁移外部公网仓库走代理时填（如服务器需代理才能访问 github）。直连留空。
# 例： GITEA_PROXY_URL=http://host.docker.internal:7897
GITEA_PROXY_URL=
