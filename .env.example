# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=gitguild
MYSQL_PASSWORD=gitguild123

# ── Redis（开发环境无密码；生产环境建议配置 ACL）──────────────────────────────
# REDIS_PASSWORD=

# ── SMTP 邮件（忘记密码验证码 / 邮件通知用；不配置时发信失败但接口不报错）────────
# 默认按 163 邮箱配置：MAIL_USERNAME 填完整邮箱地址，MAIL_PASSWORD 填「客户端授权码」
# （在 163 网页版「设置 → POP3/SMTP/IMAP」开启服务后获取，不是邮箱登录密码）。
# 团队共享邮箱 gitguild@163.com 的授权码请向负责人私下索取，切勿提交到 Git。
# 465 端口走 SSL（application.yml 已配 ssl.enable=true）；若用 25/587 端口需改走 starttls。
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=gitguild@163.com
MAIL_PASSWORD=your_163_authorization_code

# ── Gitea ──────────────────────────────────────────────────────────────────────
# 演示无需配置：后端已内置随仓库分发快照的 demo token 作为默认值（见 application.yml）。
# 仅当你换用自己的 Gitea 时，才在这里覆盖 base-url / token。
GITEA_BASE_URL=http://localhost:3000
GITEA_TOKEN=

# ── JWT（生产环境必须替换为 32 字符以上的随机字符串）─────────────────────────
JWT_SECRET=dev-secret-please-change-in-production-env
JWT_EXPIRATION_MS=86400000

# ── AI 前台向导（DeepSeek，API Key 不要提交到 Git）──────────────────────────
ASSISTANT_AI_ENABLED=true
ASSISTANT_AI_PROVIDER=deepseek
ASSISTANT_AI_BASE_URL=https://api.deepseek.com/v1
ASSISTANT_AI_API_KEY=
ASSISTANT_AI_MODEL=deepseek-chat
