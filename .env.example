# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=gitguild
MYSQL_PASSWORD=gitguild123

# ── Redis（开发环境无密码；生产环境建议配置 ACL）──────────────────────────────
# REDIS_PASSWORD=

# ── SMTP 邮件（可选，不配置时邮件通知不可用）──────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password

# ── Gitea ──────────────────────────────────────────────────────────────────────
# 推荐用 scripts/setup-gitea.sh 自动：建管理员、生成 token（自动写回本文件 GITEA_TOKEN）、建演示仓库与 Issue。
GITEA_BASE_URL=http://localhost:3000
GITEA_TOKEN=
# Gitea 尚无管理员时，setup-gitea.sh 用此密码创建 spike-admin 并据此签发 token（仅本地演示）
GITEA_ADMIN_PASSWORD=Gitguild-demo-2026

# ── JWT（生产环境必须替换为 32 字符以上的随机字符串）─────────────────────────
JWT_SECRET=dev-secret-please-change-in-production-env
JWT_EXPIRATION_MS=86400000
