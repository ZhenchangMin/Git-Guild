# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=gitguild
MYSQL_PASSWORD=gitguild123

# ── Redis（开发环境无密码；生产环境建议配置 ACL）──────────────────────────────
# REDIS_PASSWORD=

# ── SMTP 邮件（可选，不配置时邮件通知不可用）──────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password

# ── Gitea（启动容器后，在 http://localhost:3000 完成初始化，再生成 token）──────
GITEA_BASE_URL=http://localhost:3000
GITEA_TOKEN=

# ── JWT（生产环境必须替换为 32 字符以上的随机字符串）─────────────────────────
JWT_SECRET=dev-secret-please-change-in-production-env
JWT_EXPIRATION_MS=86400000
