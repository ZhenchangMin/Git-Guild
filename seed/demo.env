# 最短 MVP 演示用环境变量 —— bootstrap.sh 会把本文件复制为项目根的 .env。
#
# ⚠️ 仅本地演示用：下面的 GITEA_TOKEN 只对随仓库分发的「本地一次性 Gitea 快照」
#    （seed/gitea-data.tar.gz）有效，等同于演示弱密码 admin123，不是生产凭据。
#    每位队友各跑各自的 localhost:3000 Gitea，这个 token 在公网上没有任何意义。

# ── MySQL ──
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=gitguild
MYSQL_PASSWORD=gitguild123

# ── Redis ──
# REDIS_PASSWORD=

# ── SMTP（演示不需要，留占位）──
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password

# ── Gitea（token 与 seed/gitea-data.tar.gz 快照内的 spike-admin 令牌一致）──
GITEA_BASE_URL=http://localhost:3000
GITEA_TOKEN=38f08180132021c3ebe7d777c6931b664997fd89

# ── JWT ──
JWT_SECRET=dev-secret-please-change-in-production-env
JWT_EXPIRATION_MS=86400000
